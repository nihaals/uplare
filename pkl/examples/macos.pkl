amends "../MacOs.pkl"

mac {
  homebrew = new Homebrew {
    explicitlyInstalledFormulae {
      "ffmpeg"
    }
    nonAppCasks {
      "font-fira-code"
    }
  }
  apps {
    new ManualApp {
      name = "Wolfram"
      appPaths {
        "/Applications/Wolfram.app"
      }
    }
    new HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    }
    new MacAppStoreApp {
      appStoreId = 497799835
      appPaths {
        "/Applications/Xcode.app"
      }
    }
  }
}
