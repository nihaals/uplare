amends "../SteamOs.pkl"

steamOs {
  hostname = "my-device"
  steamOsSettings {}
  steamSettings {
    twentyFourHourClock = true
  }
  installedFlatpaks {
    "org.mozilla.firefox"
    "com.github.Matoking.protontricks"
  }
  decky = new Decky {
    settings {}
    local plugins: Listing<DeckyPlugin(directoryName != null)>(
      toList().sortBy((plugin) -> plugin.name) == toList(),
    ) = new {
      new {
        name = "Brightness Bar"
        directoryName = "decky-brightness-bar"
      }
      new {
        name = "HLTB for Deck"
        directoryName = "hltb-for-deck"
        disabled = true
      }
    }
    plugins = plugins
  }
}
