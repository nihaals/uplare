amends "pkl:Project"

local github = new {
  owner = "nihaals"
  repo = "uplare"
  pkgPkl = "pkg.pkl-lang.org/github.com/\(owner)/\(repo)"
  githubUrl = "https://github.com/\(owner)/\(repo)"
}

local cargoToml = read("../Cargo.toml")
local cargoTomlVersion = cargoToml.text.splitLimit("\nversion = \"", 2)[1].splitLimit("\"", 2)[0]

package {
  name = "uplare"
  baseUri = "package://\(github.pkgPkl)/\(name)"
  version = cargoTomlVersion
  packageZipUrl = "\(github.githubUrl)/releases/download/\(name)@\(version)/\(name)@\(version).zip"
  description = "Pkl templates for Uplare"
  sourceCode = github.githubUrl
  website = sourceCode
  license = "GPL-3.0"
  issueTracker = "\(github.githubUrl)/issues"
  apiTests = tests
}

tests = import*("tests/**.pkl").keys.toListing()
