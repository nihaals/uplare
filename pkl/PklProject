amends "pkl:Project"

local github = new {
  owner = "nihaals"
  repo = "uplare"
  githubUrlSchemeless = "github.com/\(owner)/\(repo)"
  githubUrl = "https://github.com/\(owner)/\(repo)"
}

local cargoToml = read("../Cargo.toml")
local cargoTomlVersion = cargoToml.text.splitLimit("\nversion = \"", 2)[1].splitLimit("\"", 2)[0]

package {
  name = "uplare"
  version = cargoTomlVersion
  // `pkg.pkl-lang.org/github.com/*/*/*` requires release tags to be named the same as the release asset
  // We use `v<version>` as our tag names and `<name>-pkl@<version>` as our release asset name (derived from last
  // segment of `baseUri`) so we have to use the whole GitHub release asset download URL
  local tagName = "v\(version)"
  local releaseAssetPrefix = "\(name)-pkl"
  baseUri =
    "package://\(github.githubUrlSchemeless)/releases/download/\(tagName)/\(releaseAssetPrefix)"
  packageZipUrl =
    "\(github.githubUrl)/releases/download/\(tagName)/\(releaseAssetPrefix)@\(version).zip"
  description = "Pkl templates for Uplare"
  sourceCode = github.githubUrl
  website = sourceCode
  license = "GPL-3.0"
  issueTracker = "\(github.githubUrl)/issues"
  apiTests = tests
}

tests = import*("tests/**.pkl").keys.toListing()
