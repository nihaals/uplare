amends "pkl:test"

import "../MacOs.pkl"

local function noConstraintViolation(value: Any): Boolean =
  module.catchOrNull(() -> value.toString()) == null
local function constraintViolation(value: Any): Boolean =
  module.catchOrNull(() -> value.toString())?.startsWith("Type constraint ") ?? false

facts {
  // -- App path validation (BaseMacApp) --

  ["allows valid app path"] {
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows zip in app path"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.zip"
      }
    })
  }
  ["disallows trailing slash in app path"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app/"
      }
    })
  }
  ["disallows relative app path"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "Applications/Visual Studio Code.app"
      }
    })
  }

  // -- ManualApp --

  ["allows manual app with multiple app paths"] {
    noConstraintViolation(new MacOs.ManualApp {
      name = "Visual Studio Code"
      appPaths {
        "/Applications/Visual Studio Code.app"
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
  }
  ["disallows manual app with empty name"] {
    constraintViolation(new MacOs.ManualApp {
      name = ""
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }

  // -- HomebrewCask --

  ["allows valid cask"] {
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "~/Applications/Visual Studio Code.app"
      }
    })
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code@insiders"
      appPaths {
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "a"
      appPaths {
        "/Applications/a.app"
      }
    })
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "user/repo/visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "homebrew/cask/visual-studio-code@insiders"
      appPaths {
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
  }
  ["allows cask with multiple app paths"] {
    noConstraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
  }
  ["disallows empty cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = ""
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows exclamation mark in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code!"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "!visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual!-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows leading and trailing dash in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "-visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code-"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows leading and trailing @ in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "@visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code@"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows multiple @ in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code@@insiders"
      appPaths {
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code@i@nsiders"
      appPaths {
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
  }
  ["disallows dot after @ in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio-code@1.2"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows double dash in cask name"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "visual-studio--code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows cask name with one slash"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "repo/visual-studio-code"
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows cask name with more than two slashes"] {
    constraintViolation(new MacOs.HomebrewCask {
      caskName = "homebrew/cask/fonts/font-fira-code"
      appPaths {
        "/Applications/Font Fira Code.app"
      }
    })
  }

  // -- Homebrew --

  ["allows homebrew with no taps"] {
    noConstraintViolation(new MacOs.Homebrew {
      taps {}
    })
  }
  ["allows homebrew with taps"] {
    noConstraintViolation(new MacOs.Homebrew {
      taps {
        "homebrew/cask"
        "homebrew/core"
      }
    })
  }
  ["disallows duplicate taps"] {
    constraintViolation(new MacOs.Homebrew {
      taps {
        "homebrew/cask"
        "homebrew/cask"
      }
    })
  }
  ["disallows tap with no slash"] {
    constraintViolation(new MacOs.Homebrew {
      taps {
        "homebrew"
      }
    })
  }
  ["disallows tap with two slashes"] {
    constraintViolation(new MacOs.Homebrew {
      taps {
        "homebrew/cask/fonts"
      }
    })
  }
  ["allows homebrew with explicitly installed formulae"] {
    noConstraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "xz"
        "ca-certificates"
        "hdrhistogram_c"
        "python@3.14"
        "llama.cpp"
        "homebrew/core/openssl@3"
      }
    })
  }
  ["disallows invalid explicitly installed formula"] {
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "hdrhistogram__c"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "ca-certificates!"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "python.3@14"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "@python"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "python@"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "python@@3"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "python@3@14"
      }
    })
  }
  ["disallows duplicate explicitly installed formulae"] {
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "xz"
        "xz"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "homebrew/core/openssl@3"
        "openssl@3"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      explicitlyInstalledFormulae {
        "homebrew/core/openssl@3"
        "user/repo/openssl@3"
      }
    })
  }
  ["allows homebrew with no non-app casks"] {
    noConstraintViolation(new MacOs.Homebrew {
      nonAppCasks {}
    })
  }
  ["allows homebrew with non-app casks"] {
    noConstraintViolation(new MacOs.Homebrew {
      nonAppCasks {
        "font-fira-code"
        "macfuse"
        "homebrew/cask/font-fira-code-nerd-font"
      }
    })
  }
  ["disallows invalid non-app cask name"] {
    constraintViolation(new MacOs.Homebrew {
      nonAppCasks {
        "font-fira-code!"
      }
    })
  }
  ["disallows duplicate non-app cask names"] {
    constraintViolation(new MacOs.Homebrew {
      nonAppCasks {
        "font-fira-code"
        "font-fira-code"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      nonAppCasks {
        "homebrew/cask/font-fira-code"
        "font-fira-code"
      }
    })
    constraintViolation(new MacOs.Homebrew {
      nonAppCasks {
        "homebrew/cask/font-fira-code"
        "user/repo/font-fira-code"
      }
    })
  }

  // -- MacAppStoreApp --

  ["disallows app store app with 0 app id"] {
    constraintViolation(new MacOs.MacAppStoreApp {
      appStoreId = 0
      appPaths {
        "/Applications/Visual Studio Code.app"
      }
    })
  }
  ["disallows app store app with multiple app paths"] {
    constraintViolation(new MacOs.MacAppStoreApp {
      appStoreId = 1
      appPaths {
        "/Applications/Visual Studio Code.app"
        "/Applications/Visual Studio Code - Insiders.app"
      }
    })
  }

  // -- TestFlightApp --

  ["allows valid testflight app"] {
    noConstraintViolation(new MacOs.TestFlightApp {
      name = "My App"
      appPaths {
        "/Applications/My App.app"
      }
    })
  }
  ["disallows testflight app with empty name"] {
    constraintViolation(new MacOs.TestFlightApp {
      name = ""
      appPaths {
        "/Applications/My App.app"
      }
    })
  }
  ["disallows testflight app with multiple app paths"] {
    constraintViolation(new MacOs.TestFlightApp {
      name = "My App"
      appPaths {
        "/Applications/My App.app"
        "/Applications/My App 2.app"
      }
    })
  }

  // -- MacOsConfig --

  ["disallows empty apps"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {}
    })
    constraintViolation(new MacOs.MacOs {
      apps {}
    })
  }
  ["allows cask with homebrew"] {
    noConstraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
    noConstraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
  }
  ["allows non-cask with homebrew"] {
    noConstraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
  }
  ["disallows cask with no homebrew"] {
    constraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
    constraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
  }
  ["allows non-cask with no homebrew"] {
    noConstraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
  }
  ["disallows duplicate app paths"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code-2"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
  }
  ["disallows duplicate cask names"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
  }
  ["allows casks with the same tap and different cask names"] {
    noConstraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "homebrew/cask/visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "homebrew/cask/visual-studio-code@insiders"
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
  }
  ["disallows duplicate cask name ends"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "homebrew/cask/visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.HomebrewCask {
          caskName = "homebrew/cask/visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.HomebrewCask {
          caskName = "user/repo/visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
  }
  ["disallows casks in both nonAppCasks and apps"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {
        nonAppCasks {
          "visual-studio-code"
        }
      }
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {
        nonAppCasks {
          "homebrew/cask/visual-studio-code"
        }
      }
      apps {
        new MacOs.HomebrewCask {
          caskName = "visual-studio-code"
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
      }
    })
  }
  ["disallows duplicate app store ids"] {
    constraintViolation(new MacOs.MacOs {
      homebrew = new MacOs.Homebrew {}
      apps {
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code.app"
          }
        }
        new MacOs.MacAppStoreApp {
          appStoreId = 1
          appPaths {
            "/Applications/Visual Studio Code - Insiders.app"
          }
        }
      }
    })
  }
  ["disallows duplicate testflight names"] {
    constraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.TestFlightApp {
          name = "My App"
          appPaths {
            "/Applications/My App.app"
          }
        }
        new MacOs.TestFlightApp {
          name = "My App"
          appPaths {
            "/Applications/My App 2.app"
          }
        }
      }
    })
  }
  ["disallows duplicate manual names"] {
    constraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.ManualApp {
          name = "My App"
          appPaths {
            "/Applications/My App.app"
          }
        }
        new MacOs.ManualApp {
          name = "My App"
          appPaths {
            "/Applications/My App 2.app"
          }
        }
      }
    })
  }
  ["disallows duplicate name across manual and testflight apps"] {
    constraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.ManualApp {
          name = "My App"
          appPaths {
            "/Applications/My App.app"
          }
        }
        new MacOs.TestFlightApp {
          name = "My App"
          appPaths {
            "/Applications/My App 2.app"
          }
        }
      }
    })
  }
  ["allows manual and testflight apps with different names"] {
    noConstraintViolation(new MacOs.MacOs {
      apps {
        new MacOs.ManualApp {
          name = "My App"
          appPaths {
            "/Applications/My App.app"
          }
        }
        new MacOs.TestFlightApp {
          name = "My Other App"
          appPaths {
            "/Applications/My Other App.app"
          }
        }
      }
    })
  }
}
