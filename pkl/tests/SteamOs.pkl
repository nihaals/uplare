amends "pkl:test"

import "../FileCheck.pkl"
import "../SteamOs.pkl"

local function noConstraintViolation(value: Any): Boolean =
  module.catchOrNull(() -> value.toString()) == null
local function constraintViolation(value: Any): Boolean =
  module.catchOrNull(() -> value.toString())?.startsWith("Type constraint ") ?? false

facts {
  // -- installedFlatpaks --

  ["allows flatpaks"] {
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {
        "org.mozilla.firefox"
      }
    })
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {
        "org.mozilla.firefox"
        "net.lutris.Lutris"
      }
    })
  }
  ["disallows flatpak with no dot"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {
        "firefox"
      }
    })
  }
  ["disallows duplicate flatpaks"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {
        "org.mozilla.firefox"
        "org.mozilla.firefox"
      }
    })
  }

  // -- enabledSystemdUnits --

  ["allows systemd units"] {
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      enabledSystemdUnits {
        "sshd.service"
      }
    })
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      enabledSystemdUnits {
        "sshd.service"
        "avahi-daemon.service"
      }
    })
  }
  ["disallows systemd unit with no dot"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      enabledSystemdUnits {
        "sshd"
      }
    })
  }
  ["disallows duplicate systemd units"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      enabledSystemdUnits {
        "sshd.service"
        "sshd.service"
      }
    })
  }

  // -- desktop --

  ["allows desktop entries"] {
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      desktop = new Listing {
        "Return.desktop"
      }
    })
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      desktop = new Listing {
        "Return.desktop"
        "steam.desktop"
      }
    })
  }
  ["disallows duplicate desktop entries"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      desktop = new Listing {
        "Return.desktop"
        "Return.desktop"
      }
    })
  }

  // -- kdePlasmaDock --

  ["allows kde plasma dock entries"] {
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      kdePlasmaDock = new Listing {
        "Return.desktop"
      }
    })
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      kdePlasmaDock = new Listing {
        "Return.desktop"
        "steam.desktop"
      }
    })
  }
  ["disallows duplicate kde plasma dock entries"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      installedFlatpaks {}
      kdePlasmaDock = new Listing {
        "Return.desktop"
        "Return.desktop"
      }
    })
  }

  // -- files --

  ["allows distinct file checks"] {
    noConstraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      files {
        new FileCheck.FileExists {
          path = "/etc/hosts"
        }
        new FileCheck.DirectoryExists {
          path = "/etc/"
        }
      }
    })
  }
  ["disallows duplicate file check paths"] {
    constraintViolation(new SteamOs.SteamOs {
      hostname = "test"
      steamOsSettings {}
      steamSettings {
        twentyFourHourClock = true
      }
      files {
        new FileCheck.FileExists {
          path = "/etc/hosts"
        }
        new FileCheck.FileEqualsString {
          path = "/etc/hosts"
          contents = "127.0.0.1 localhost\n"
        }
      }
    })
  }

  // -- chargeLimit --

  ["allows charge limit"] {
    noConstraintViolation(new SteamOs.SteamOsSettings {
      chargeLimit = 50
    })
    noConstraintViolation(new SteamOs.SteamOsSettings {
      chargeLimit = 60
    })
    noConstraintViolation(new SteamOs.SteamOsSettings {
      chargeLimit = 100
    })
  }
  ["disallows invalid charge limit"] {
    constraintViolation(new SteamOs.SteamOsSettings {
      chargeLimit = 101
    })
    constraintViolation(new SteamOs.SteamOsSettings {
      chargeLimit = -1
    })
  }

  // -- plugins --

  ["allows decky plugins"] {
    noConstraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
        }
      }
    })
    noConstraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
        }
        new {
          name = "ProtonDB Badges"
          disabled = true
        }
      }
    })
  }
  ["allows decky plugin directory names"] {
    noConstraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
          directoryName = "hltb-for-deck"
        }
      }
    })
    noConstraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
          directoryName = "hltb-for-deck"
        }
        new {
          name = "ProtonDB Badges"
          directoryName = "protondb-decky"
          disabled = true
        }
      }
    })
  }
  ["disallows invalid decky plugin directory names"] {
    constraintViolation(new SteamOs.DeckyPlugin {
      name = "HLTB for Deck"
      directoryName = ""
    })
    constraintViolation(new SteamOs.DeckyPlugin {
      name = "HLTB for Deck"
      directoryName = "hltb_for_deck"
    })
  }
  ["disallows duplicate decky plugins"] {
    constraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
        }
        new {
          name = "HLTB for Deck"
        }
      }
    })
    constraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
        }
        new {
          name = "HLTB for Deck"
          disabled = true
        }
      }
    })
  }
  ["disallows duplicate decky plugin directory names"] {
    constraintViolation(new SteamOs.Decky {
      settings {}
      plugins {
        new {
          name = "HLTB for Deck"
          directoryName = "shared-directory"
        }
        new {
          name = "ProtonDB Badges"
          directoryName = "shared-directory"
          disabled = true
        }
      }
    })
  }
}
