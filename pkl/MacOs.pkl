module uplare.MacOs

mac: MacOs
class MacOs {
  installHomebrew: Boolean
  apps: Listing<MacApp>(
    isNotEmpty
      && ifFalseExcludesClass(installHomebrew, HomebrewCask, this)
      && toList().flatMap((app) -> app.appPaths.toList()).isDistinct
      && toList().filterIsInstance(HomebrewCask).isDistinctBy((app) -> app.caskName)
      && toList().filterIsInstance(MacAppStoreApp).isDistinctBy((app) -> app.appStoreId)
      && toList()
        .filter((app) -> app is ManualApp || app is TestFlightApp)
        .isDistinctBy((app) -> (app as (ManualApp | TestFlightApp)).name),
  )
}

typealias MacApp = ManualApp | HomebrewCask | MacAppStoreApp | TestFlightApp
typealias MacAppPath =
  String((startsWith("/Applications/") || startsWith("~/Applications/")) && !endsWith("/"))

/// If [bool] is `false` then [listing] must not contain any item with class [`class`].
local const function ifFalseExcludesClass(bool: Boolean, `class`: Class, listing: Listing<Any>) =
  if (bool) true else listing.every((item) -> item.getClass() != `class`)

/// If [bool] is `true` then [listing] must be length 1.
local const function isLengthOne(bool: Boolean, listing: Listing<Any>) =
  if (bool) listing.length == 1 else true

abstract local class BaseMacApp {
  fixed type: String = getClass().simpleName
  hidden singleAppPath: Boolean = false
  appPaths: Listing<MacAppPath>(isNotEmpty && isDistinct && isLengthOne(singleAppPath, this))
}

class ManualApp extends BaseMacApp {
  name: String(isNotEmpty)
}

class HomebrewCask extends BaseMacApp {
  caskName: String(matches(Regex(#"(?!.*--)(?!.*@.*@)[a-z0-9]([a-z0-9-@]*[a-z0-9])?"#)))
}

class MacAppStoreApp extends BaseMacApp {
  hidden singleAppPath = true
  appStoreId: UInt(isNonZero)
}

class TestFlightApp extends BaseMacApp {
  hidden singleAppPath = true
  name: String(isNotEmpty)
}

output {
  value = mac
  renderer = new JsonRenderer {}
}
